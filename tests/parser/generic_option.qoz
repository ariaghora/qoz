import strings
import fmt

type Maybe<T> =
    | Just(T)
    | Nothing

let main() = {
    let opt_int = Maybe.Just(42)
    match opt_int {
    | Maybe.Just(v)  -> fmt.println(`int: {v}`)
    | Maybe.Nothing  -> fmt.println("nothing")
    }

    let opt_str = Maybe.Just("hello")
    match opt_str {
    | Maybe.Just(s)  -> fmt.println(`str: {s}`)
    | Maybe.Nothing  -> fmt.println("nothing")
    }
}
