// stage-b-skip: Stage B has no SLetElse AST yet; the test relies on
// `let Pattern = expr else { ... }` syntax which Stage A supports.
import std/strings
import std/fmt

type Option =
    | None
    | Some(i64)

let unwrap_or_zero(opt: Option): i64 = {
    let Option.Some(v) = opt else {
        return 0
    }
    v
}

let main() = {
    fmt.println("Some(7) => {unwrap_or_zero(Option.Some(7))}")
    fmt.println("None    => {unwrap_or_zero(Option.None)}")
}
