import std/fmt
import std/strings
import std/vec

let main() = {
    let parts = strings.split("alpha,beta,gamma,delta", 44)
    fmt.println("count =", len(parts))
    var i: i64 = 0
    while i < len(parts) {
        fmt.println(parts[i])
        i = i + 1
    }

    fmt.println("has_prefix(hello world, hello) =", strings.has_prefix("hello world", "hello"))
    fmt.println("has_suffix(hello world, world) =", strings.has_suffix("hello world", "world"))
    fmt.println("parse_int(42) =", strings.parse_int("42"))
    fmt.println("parse_int(-7) =", strings.parse_int("-7"))
}
