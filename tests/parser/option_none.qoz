import strings
import fmt

type Maybe<T> =
    | Just(T)
    | Nothing

let main() = {
    let a: Maybe<i32> = Maybe.Nothing
    let b: Maybe<i32> = Maybe.Just(7)
    match a {
    | Maybe.Just(v)  -> fmt.println(`a: {v}`)
    | Maybe.Nothing  -> fmt.println("a: nothing")
    }
    match b {
    | Maybe.Just(v)  -> fmt.println(`b: {v}`)
    | Maybe.Nothing  -> fmt.println("b: nothing")
    }
}
