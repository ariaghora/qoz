// expect: 7
// Generic two-arm ADT with pattern binding. Uses a user-defined name
// so it does not shadow the prelude's Result.

type Outcome<T, E> =
    | Got(T)
    | Bad(E)

let unwrap_default<T, E>(r: Outcome<T, E>, fallback: T): T = match r {
| Got(x) -> x
| Bad(_) -> fallback
}

let main(): i64 = {
    let ok: Outcome<i64, i64> = Got(7)
    let er: Outcome<i64, i64> = Bad(99)
    unwrap_default(ok, 0) + unwrap_default(er, 0)
}
