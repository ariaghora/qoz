// expect: 5
//
// Generic ADT Option<T> exercises enum monomorphisation. The unwrap_or
// helper is generic and called with no turbofish; T is inferred from the
// argument and from the default value's type.

type Option<T> =
    | Some(T)
    | None

let unwrap_or<T>(o: Option<T>, fallback: T): T = match o {
| Some(x) -> x
| None    -> fallback
}

let main(): i64 = {
    let some: Option<i64> = Some(5)
    let none: Option<i64> = None
    unwrap_or(some, 0) + unwrap_or(none, 0)
}
