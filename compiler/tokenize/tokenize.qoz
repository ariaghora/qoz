// compiler/tokenize: Stage B tokenizer for Qoz source.

import std/strings
import std/vec
import std/map

type TokenKind =
    | TokIdent
    | TokInt
    | TokString
    | TokPunct
    | TokKeyword
    | TokEOF

type Token = {
    kind: TokenKind,
    text: string,
    line: i64,
    col:  i64,
}

type Lexer = {
    src:    string,
    pos:    i64,
    line:   i64,
    col:    i64,
}

let make_lexer(src: string): Lexer = Lexer { src: src, pos: 0, line: 1, col: 1 }

let lex_at(l: *Lexer): i64 = strings.byte_at(l.src, l.pos)

let lex_advance(l: *Lexer) = {
    let c = lex_at(l)
    l.pos = l.pos + 1
    if c == 10 {
        l.line = l.line + 1
        l.col = 1
    } else {
        l.col = l.col + 1
    }
}

let is_space(c: i64): bool = c == 32 || c == 9 || c == 10 || c == 13
let is_digit(c: i64): bool = c >= 48 && c <= 57
let is_alpha(c: i64): bool = (c >= 65 && c <= 90) || (c >= 97 && c <= 122) || c == 95
let is_alnum(c: i64): bool = is_alpha(c) || is_digit(c)

let is_punct(c: i64): bool =
    c == 40 || c == 41 || c == 123 || c == 125 || c == 91 || c == 93 ||
    c == 44 || c == 59 || c == 46 || c == 58 || c == 61 ||
    c == 43 || c == 45 || c == 42 || c == 47 || c == 37 ||
    c == 60 || c == 62 || c == 33 || c == 38 || c == 124 || c == 64 || c == 63

let skip_whitespace_and_comments(l: *Lexer) = {
    var changed = true
    while changed {
        changed = false
        while l.pos < len(l.src) && is_space(lex_at(l)) {
            lex_advance(l)
            changed = true
        }
        if l.pos + 1 < len(l.src) && lex_at(l) == 47 && strings.byte_at(l.src, l.pos + 1) == 47 {
            while l.pos < len(l.src) && lex_at(l) != 10 {
                lex_advance(l)
            }
            changed = true
        }
        if l.pos + 1 < len(l.src) && lex_at(l) == 47 && strings.byte_at(l.src, l.pos + 1) == 42 {
            lex_advance(l); lex_advance(l)
            var depth: i64 = 1
            while depth > 0 && l.pos < len(l.src) {
                if l.pos + 1 < len(l.src) && lex_at(l) == 47 && strings.byte_at(l.src, l.pos + 1) == 42 {
                    lex_advance(l); lex_advance(l); depth = depth + 1
                } else if l.pos + 1 < len(l.src) && lex_at(l) == 42 && strings.byte_at(l.src, l.pos + 1) == 47 {
                    lex_advance(l); lex_advance(l); depth = depth - 1
                } else {
                    lex_advance(l)
                }
            }
            changed = true
        }
    }
}

let is_keyword(kw: *Map<string, bool>, s: string): bool = {
    match map.get(kw, s) {
    | Some(_) -> true
    | None    -> false
    }
}

let build_keywords(): Map<string, bool> = {
    var m: Map<string, bool> = map.make()
    m["let"]      = true
    m["var"]      = true
    m["type"]     = true
    m["if"]       = true
    m["else"]     = true
    m["match"]    = true
    m["while"]    = true
    m["for"]      = true
    m["in"]       = true
    m["return"]   = true
    m["defer"]    = true
    m["import"]   = true
    m["external"] = true
    m["as"]       = true
    m["new"]      = true
    m["true"]     = true
    m["false"]    = true
    m["nil"]      = true
    m
}

let lex_one(l: *Lexer, kw: *Map<string, bool>): Token = {
    skip_whitespace_and_comments(l)
    if l.pos >= len(l.src) {
        return Token { kind: TokEOF, text: "", line: l.line, col: l.col }
    }
    let start_pos = l.pos
    let start_line = l.line
    let start_col  = l.col
    let c = lex_at(l)

    if is_digit(c) {
        while l.pos < len(l.src) && is_digit(lex_at(l)) {
            lex_advance(l)
        }
        return Token { kind: TokInt, text: strings.slice(l.src, start_pos, l.pos), line: start_line, col: start_col }
    }

    if is_alpha(c) {
        while l.pos < len(l.src) && is_alnum(lex_at(l)) {
            lex_advance(l)
        }
        let word = strings.slice(l.src, start_pos, l.pos)
        var k: TokenKind = TokIdent
        if is_keyword(kw, word) {
            k = TokKeyword
        }
        return Token { kind: k, text: word, line: start_line, col: start_col }
    }

    if c == 34 {
        lex_advance(l)
        while l.pos < len(l.src) && lex_at(l) != 34 {
            if lex_at(l) == 92 && l.pos + 1 < len(l.src) {
                lex_advance(l)
            }
            lex_advance(l)
        }
        if l.pos < len(l.src) {
            lex_advance(l)
        }
        return Token { kind: TokString, text: strings.slice(l.src, start_pos, l.pos), line: start_line, col: start_col }
    }

    if is_punct(c) {
        lex_advance(l)
        if l.pos < len(l.src) {
            let n = lex_at(l)
            let two_char =
                (c == 61 && n == 61) ||
                (c == 33 && n == 61) ||
                (c == 60 && n == 61) ||
                (c == 62 && n == 61) ||
                (c == 45 && n == 62) ||
                (c == 38 && n == 38) ||
                (c == 124 && n == 124) ||
                (c == 46 && n == 46) ||
                (c == 58 && n == 58)
            if two_char {
                lex_advance(l)
                let m = lex_at(l)
                if c == 46 && n == 46 && (m == 60 || m == 61) {
                    lex_advance(l)
                }
            }
        }
        return Token { kind: TokPunct, text: strings.slice(l.src, start_pos, l.pos), line: start_line, col: start_col }
    }

    lex_advance(l)
    return Token { kind: TokPunct, text: strings.slice(l.src, start_pos, l.pos), line: start_line, col: start_col }
}

let run(src: string): Vec<Token> = {
    var out: Vec<Token> = vec.make()
    var l = make_lexer(src)
    let kw = build_keywords()
    var running = true
    while running {
        let t = lex_one(&l, &kw)
        match t.kind {
        | TokEOF     -> running = false
        | TokIdent   -> vec.push(&out, t)
        | TokInt     -> vec.push(&out, t)
        | TokString  -> vec.push(&out, t)
        | TokPunct   -> vec.push(&out, t)
        | TokKeyword -> vec.push(&out, t)
        }
    }
    out
}
