let RAYWHITE   = Color { r: 245, g: 245, b: 245, a: 255 }

// --- Window ---------------------------------------------------------

/// Initialise the window and OpenGL context.
@link_name("InitWindow")
external let init_window(width: i32, height: i32, title: cstring)

/// Close the window and free its OpenGL context.
@link_name("CloseWindow")
external let close_window()

/// True when the user clicks the close button or presses Escape.
@link_name("WindowShouldClose")
external let window_should_close(): bool

/// True when the window has been initialised successfully.
@link_name("IsWindowReady")
external let is_window_ready(): bool

@link_name("IsWindowFullscreen")
external let is_window_fullscreen(): bool

@link_name("IsWindowMinimized")
external let is_window_minimized(): bool

@link_name("IsWindowMaximized")
external let is_window_maximized(): bool

@link_name("IsWindowFocused")
external let is_window_focused(): bool

@link_name("IsWindowResized")
external let is_window_resized(): bool

/// Toggle between fullscreen and windowed. Window content is
/// rescaled to fit the new mode.
@link_name("ToggleFullscreen")
external let toggle_fullscreen()

@link_name("MaximizeWindow")
external let maximize_window()

@link_name("MinimizeWindow")
external let minimize_window()

@link_name("RestoreWindow")
external let restore_window()

@link_name("SetWindowTitle")
external let set_window_title(title: cstring)

@link_name("SetWindowPosition")
external let set_window_position(x: i32, y: i32)

@link_name("SetWindowSize")
external let set_window_size(width: i32, height: i32)

@link_name("GetScreenWidth")
external let get_screen_width(): i32

@link_name("GetScreenHeight")
external let get_screen_height(): i32

@link_name("GetRenderWidth")
external let get_render_width(): i32

@link_name("GetRenderHeight")
external let get_render_height(): i32

// --- Cursor ---------------------------------------------------------

@link_name("ShowCursor")
external let show_cursor()

@link_name("HideCursor")
external let hide_cursor()

@link_name("IsCursorHidden")
external let is_cursor_hidden(): bool

@link_name("EnableCursor")
external let enable_cursor()

@link_name("DisableCursor")
external let disable_cursor()

@link_name("IsCursorOnScreen")
external let is_cursor_on_screen(): bool

// --- Drawing ---------------------------------------------------------

/// Begin a frame. Pair with `end_drawing`. Every drawing call must
/// sit between this pair.
@link_name("BeginDrawing")
external let begin_drawing()

/// End a frame and present the back buffer.
@link_name("EndDrawing")
external let end_drawing()

/// Clear the screen to `color`.
@link_name("ClearBackground")
external let clear_background(color: Color)

@link_name("BeginMode2D")
external let begin_mode_2d(camera: Camera2D)

@link_name("EndMode2D")
external let end_mode_2d()

@link_name("BeginScissorMode")
external let begin_scissor_mode(x: i32, y: i32, width: i32, height: i32)

@link_name("EndScissorMode")
external let end_scissor_mode()

// --- Camera helpers --------------------------------------------------

@link_name("GetWorldToScreen2D")
external let get_world_to_screen_2d(position: Vector2, camera: Camera2D): Vector2

@link_name("GetScreenToWorld2D")
external let get_screen_to_world_2d(position: Vector2, camera: Camera2D): Vector2

// --- Time, FPS, random ----------------------------------------------

@link_name("SetTargetFPS")
external let set_target_fps(fps: i32)

@link_name("GetFPS")
external let get_fps(): i32

/// Seconds elapsed since the previous frame.
@link_name("GetFrameTime")
external let get_frame_time(): f32

/// Seconds elapsed since `init_window`.
@link_name("GetTime")
external let get_time(): f64

@link_name("SetRandomSeed")
external let set_random_seed(seed: u32)

/// Inclusive random integer in `[min, max]`.
@link_name("GetRandomValue")
external let get_random_value(min: i32, max: i32): i32

// --- Shape drawing ---------------------------------------------------

@link_name("DrawPixel")
external let draw_pixel(x: i32, y: i32, color: Color)

@link_name("DrawPixelV")
external let draw_pixel_v(position: Vector2, color: Color)

@link_name("DrawLine")
external let draw_line(start_x: i32, start_y: i32, end_x: i32, end_y: i32, color: Color)

@link_name("DrawLineV")
external let draw_line_v(start: Vector2, end_p: Vector2, color: Color)

@link_name("DrawLineEx")
external let draw_line_ex(start: Vector2, end_p: Vector2, thick: f32, color: Color)

@link_name("DrawCircle")
external let draw_circle(center_x: i32, center_y: i32, radius: f32, color: Color)

@link_name("DrawCircleV")
external let draw_circle_v(center: Vector2, radius: f32, color: Color)

@link_name("DrawCircleLines")
external let draw_circle_lines(center_x: i32, center_y: i32, radius: f32, color: Color)

@link_name("DrawEllipse")
external let draw_ellipse(center_x: i32, center_y: i32, radius_h: f32, radius_v: f32, color: Color)

@link_name("DrawEllipseLines")
external let draw_ellipse_lines(center_x: i32, center_y: i32, radius_h: f32, radius_v: f32, color: Color)

@link_name("DrawRing")
external let draw_ring(center: Vector2, inner_radius: f32, outer_radius: f32, start_angle: f32, end_angle: f32, segments: i32, color: Color)

@link_name("DrawRectangle")
external let draw_rectangle(x: i32, y: i32, width: i32, height: i32, color: Color)

@link_name("DrawRectangleV")
external let draw_rectangle_v(position: Vector2, size: Vector2, color: Color)

@link_name("DrawRectangleRec")
external let draw_rectangle_rec(rec: Rectangle, color: Color)

@link_name("DrawRectangleLines")
external let draw_rectangle_lines(x: i32, y: i32, width: i32, height: i32, color: Color)

@link_name("DrawRectangleLinesEx")
external let draw_rectangle_lines_ex(rec: Rectangle, line_thick: f32, color: Color)

@link_name("DrawRectangleRounded")
external let draw_rectangle_rounded(rec: Rectangle, roundness: f32, segments: i32, color: Color)

@link_name("DrawTriangle")
external let draw_triangle(v1: Vector2, v2: Vector2, v3: Vector2, color: Color)

@link_name("DrawTriangleLines")
external let draw_triangle_lines(v1: Vector2, v2: Vector2, v3: Vector2, color: Color)

@link_name("DrawPoly")
external let draw_poly(center: Vector2, sides: i32, radius: f32, rotation: f32, color: Color)

@link_name("DrawPolyLines")
external let draw_poly_lines(center: Vector2, sides: i32, radius: f32, rotation: f32, color: Color)

// --- Text ------------------------------------------------------------

@link_name("DrawText")
external let draw_text(text: cstring, x: i32, y: i32, font_size: i32, color: Color)

@link_name("MeasureText")
external let measure_text(text: cstring, font_size: i32): i32

@link_name("DrawFPS")
external let draw_fps(x: i32, y: i32)

// --- Collision -------------------------------------------------------

@link_name("CheckCollisionRecs")
external let check_collision_recs(rec1: Rectangle, rec2: Rectangle): bool

@link_name("CheckCollisionCircles")
external let check_collision_circles(center1: Vector2, radius1: f32, center2: Vector2, radius2: f32): bool

@link_name("CheckCollisionCircleRec")
external let check_collision_circle_rec(center: Vector2, radius: f32, rec: Rectangle): bool

@link_name("CheckCollisionPointRec")
external let check_collision_point_rec(point: Vector2, rec: Rectangle): bool

@link_name("CheckCollisionPointCircle")
external let check_collision_point_circle(point: Vector2, center: Vector2, radius: f32): bool

@link_name("CheckCollisionPointTriangle")
external let check_collision_point_triangle(point: Vector2, p1: Vector2, p2: Vector2, p3: Vector2): bool

@link_name("GetCollisionRec")
external let get_collision_rec(rec1: Rectangle, rec2: Rectangle): Rectangle

// --- Keyboard --------------------------------------------------------

@link_name("IsKeyPressed")
external let is_key_pressed(key: i32): bool

@link_name("IsKeyPressedRepeat")
external let is_key_pressed_repeat(key: i32): bool

@link_name("IsKeyDown")
external let is_key_down(key: i32): bool

@link_name("IsKeyReleased")
external let is_key_released(key: i32): bool

@link_name("IsKeyUp")
external let is_key_up(key: i32): bool

/// One pending keycode from the input buffer, or 0 when empty.
/// Call repeatedly in a frame to drain the queue.
@link_name("GetKeyPressed")
external let get_key_pressed(): i32

/// One pending unicode codepoint from the input buffer, or 0
/// when empty. Use for text input.
@link_name("GetCharPressed")
external let get_char_pressed(): i32

@link_name("SetExitKey")
external let set_exit_key(key: i32)

// --- Mouse -----------------------------------------------------------

@link_name("IsMouseButtonPressed")
external let is_mouse_button_pressed(button: i32): bool

@link_name("IsMouseButtonDown")
external let is_mouse_button_down(button: i32): bool

@link_name("IsMouseButtonReleased")
external let is_mouse_button_released(button: i32): bool

@link_name("IsMouseButtonUp")
external let is_mouse_button_up(button: i32): bool

@link_name("GetMouseX")
external let get_mouse_x(): i32

@link_name("GetMouseY")
external let get_mouse_y(): i32

@link_name("GetMousePosition")
external let get_mouse_position(): Vector2

@link_name("GetMouseDelta")
external let get_mouse_delta(): Vector2

@link_name("SetMousePosition")
external let set_mouse_position(x: i32, y: i32)

@link_name("SetMouseOffset")
external let set_mouse_offset(offset_x: i32, offset_y: i32)

@link_name("SetMouseScale")
external let set_mouse_scale(scale_x: f32, scale_y: f32)

@link_name("GetMouseWheelMove")
external let get_mouse_wheel_move(): f32

@link_name("GetMouseWheelMoveV")
external let get_mouse_wheel_move_v(): Vector2

// --- Gamepad ---------------------------------------------------------

@link_name("IsGamepadAvailable")
external let is_gamepad_available(gamepad: i32): bool

@link_name("IsGamepadButtonPressed")
external let is_gamepad_button_pressed(gamepad: i32, button: i32): bool

@link_name("IsGamepadButtonDown")
external let is_gamepad_button_down(gamepad: i32, button: i32): bool

@link_name("IsGamepadButtonReleased")
external let is_gamepad_button_released(gamepad: i32, button: i32): bool

@link_name("GetGamepadAxisCount")
external let get_gamepad_axis_count(gamepad: i32): i32

@link_name("GetGamepadAxisMovement")
external let get_gamepad_axis_movement(gamepad: i32, axis: i32): f32

